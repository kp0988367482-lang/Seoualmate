# Google Cloud / Firebase API Key
GOOGLE_API_KEY=your_google_api_key_here

# Firebase Admin Service Account (optional - for Firestore)
# FIREBASE_SA=path/to/service-account.json
# or use JSON directly:
# FIREBASE_SA_JSON={"type": "service_account", "project_id": "...", ...}

# Playform Backend
PLAYFORM_API=http://127.0.0.1:8000
PLAYFORM_SECRET=your-secret-key-change-in-production

# Notion API (optional - for MCP integration)
NOTION_API_KEY=your_notion_integration_key
