# ─── Firebase (Frontend) ─────────────────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Firebase (Backend / Admin SDK) ─────────────────────────
GOOGLE_API_KEY=your-google-api-key
FIREBASE_SA=path/to/service-account.json
# OR (JSON string):
# FIREBASE_SA_JSON={"type":"service_account",...}

# ─── Playform Backend API ────────────────────────────────────
VITE_API_URL=http://localhost:8000
PLAYFORM_API=http://127.0.0.1:8000
PLAYFORM_SECRET=change-this-to-a-secure-random-string

# ─── Vercel (GitHub Actions CI/CD용) ─────────────────────────
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID_LANDING=your-landing-project-id
VERCEL_PROJECT_ID_ADMIN=your-admin-project-id
